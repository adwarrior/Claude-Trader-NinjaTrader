    "max_trades_stored": 1000,
    "query_similar_count": 20,
    "enable_adaptive_learning": true
  },
  "execution": {
    "account": "Sim101",
    "instrument": "NQ 09-26",
    "quantity": 1,
    "host": "localhost",
