# Environment variables
.env

# Invalid files
nul

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
ENV/
env/

# Logs
logs/
*.log

# Data files - live/regenerable feeds, don't commit (churn every tick)
data/*.csv
data/*.csv:Zone.Identifier
data/bot_state.json
data/bot_control.json
!data/.gitkeep

# Machine-specific live/runtime state — must NOT sync across machines
# (would clobber the other machine's live tracking if pulled)
/bot_state.json
data/market_analysis.json
ati_reply.bin
.codegraph/daemon.pid
.claude/settings.local.json

# Windows Mark-of-the-Web NTFS streams surfaced as files under WSL
*:Zone.Identifier

# IDE — ignore .vscode contents but keep shared settings.json
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# NinjaTrader specific
*.bak

# Test outputs
backtest_results.json
test_results/
